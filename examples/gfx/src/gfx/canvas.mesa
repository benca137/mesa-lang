test "gfx/make_canvas_supports_dynamic_dimensions" {
    let canvas = makeCanvas(32, 18, blue())
    @assert(canvasWidth(canvas) == 32)
    @assert(canvasHeight(canvas) == 18)
    @assert(sameColor(canvasSample(canvas, point(31, 17)), blue()))
}
