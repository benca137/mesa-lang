test "inline compile reports type errors" {
    let result = @test.compile("fun broken() void {\n    println(missing)\n}\n")
    @assert(!result.ok)
    @assert(result.errors.len == 1)
    @assert(result.errors[0].code == "undefined-name")
    @assert(result.errors[0].line == 2)
    @assert(result.errors[0].col == 13)
}

test "inline compile reports parse errors" {
    let result = @test.compile("fun broken( void {\n}\n")
    @assert(!result.ok)
    @assert(result.errors.len > 0)
    @assert(result.errors[0].message != "")
}

test "inline compile reports interface method visibility mismatch" {
    let result = @test.compile("interface I { pub fun f(self: @this) i64; }\nstruct S {}\ndef I for S { fun f(self: S) i64 { return 1; } }\n")
    @assert(!result.ok)
    @assert(result.errors.len > 0)
}

