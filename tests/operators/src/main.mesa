test "operators/addr_deref_ok.mesa" {
    @assert(operators__addr_deref_ok__f() == 42)
}
test "operators/addr_in_call_ok.mesa" {
    let var s: operators__addr_in_call_ok__S = .{x: 1}
    operators__addr_in_call_ok__zero(&s)
    @assert(s.x == 0)
}
test "operators/arith_f32_add_ok.mesa" {
    @assert(operators__arith_f32_add_ok__f(7.5, 2.5) == 10.0)
}
test "operators/arith_f32_div_ok.mesa" {
    @assert(operators__arith_f32_div_ok__f(7.5, 2.5) == 3.0)
}
test "operators/arith_f32_mul_ok.mesa" {
    @assert(operators__arith_f32_mul_ok__f(7.5, 2.5) == 18.75)
}
test "operators/arith_f32_sub_ok.mesa" {
    @assert(operators__arith_f32_sub_ok__f(7.5, 2.5) == 5.0)
}
test "operators/arith_f64_add_ok.mesa" {
    @assert(operators__arith_f64_add_ok__f(7.5, 2.5) == 10.0)
}
test "operators/arith_f64_div_ok.mesa" {
