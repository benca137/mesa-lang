    let var counter: interfaces__interface_returns_self_ok__Counter = .{ n: 9 }
    counter.reset()
    @assert(counter.n == 0)
}

test "interfaces/interface_two_methods_ok.mesa" {
    let sq: interfaces__interface_two_methods_ok__Square = .{ side: 4.0 }
    @assert(sq.area() == 16.0)
    @assert(sq.perimeter() == 16.0)
}

test "interfaces/interface_with_bool_method_ok.mesa" {
    let pos: interfaces__interface_with_bool_method_ok__Positive = .{ val: 3.0 }
    let neg: interfaces__interface_with_bool_method_ok__Positive = .{ val: -1.0 }
    @assert(pos.check())
    @assert(!neg.check())
}

test "interfaces/interface_method_visibility_ok.mesa" {
    let b: interfaces__interface_method_visibility_ok__Box = .{ n: 42 }
    @assert(b.value() == 42)
}

test "interfaces/interface_with_default_ok.mesa" {
    let n: interfaces__interface_with_default_ok__Num = .{ val: 12 }
    @assert(n.to_str() == "num")
    @assert(n.val == 12)
}

test "interfaces/multiple_interfaces_ok.mesa" {
    let a: interfaces__multiple_interfaces_ok__Vec2 = .{ x: 1.0, y: 2.0 }
    let b: interfaces__multiple_interfaces_ok__Vec2 = .{ x: 3.0, y: -4.0 }
    let sum = interfaces__multiple_interfaces_ok__f(a, b)
    let neg = a.neg()
    @assert(sum.x == 4.0)
    @assert(sum.y == -2.0)
    @assert(neg.x == -1.0)
    @assert(neg.y == -2.0)
}

