}

test "interfaces/basic_interface_ok.mesa" {
    let c: interfaces__basic_interface_ok__Circle = .{ r: 3.0 }
    @assert(interfaces__basic_interface_ok__f(c) == 9.0)
    @assert(c.area() == 9.0)
}

test "interfaces/def_multiple_structs_ok.mesa" {
    let input2: interfaces__def_multiple_structs_ok__Vec2 = .{ x: 9.0, y: -4.0 }
    let input3: interfaces__def_multiple_structs_ok__Vec3 = .{ x: 1.0, y: 2.0, z: 3.0 }
    let v2 = input2.zero()
    let v3 = input3.zero()
    @assert(v2.x == 0.0)
    @assert(v2.y == 0.0)
    @assert(v3.x == 0.0)
    @assert(v3.y == 0.0)
    @assert(v3.z == 0.0)
}

test "interfaces/extra_method_ok.mesa" {
    let p: interfaces__extra_method_ok__Person = .{ name: "Ada" }
    @assert(p.hi() == "Ada")
    @assert(p.bye() == "Ada")
}

test "interfaces/iface_returns_bool_ok.mesa" {
    let yes: interfaces__iface_returns_bool_ok__S = .{ v: true }
    let no: interfaces__iface_returns_bool_ok__S = .{ v: false }
    @assert(yes.val())
    @assert(!no.val())
}

