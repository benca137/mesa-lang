    let circle: interfaces__impl_for_multiple_structs_ok__Circle = .{ r: 4.0 }
    let rect: interfaces__impl_for_multiple_structs_ok__Rect = .{ w: 3.0, h: 5.0 }
    @assert(circle.area() == 16.0)
    @assert(rect.area() == 15.0)
}

