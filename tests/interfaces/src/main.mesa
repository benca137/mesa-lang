def interfaces__multiple_interfaces_ok__Add, interfaces__multiple_interfaces_ok__Neg for interfaces__multiple_interfaces_ok__Vec2 {
    fun add(self: interfaces__multiple_interfaces_ok__Vec2, other: interfaces__multiple_interfaces_ok__Vec2) interfaces__multiple_interfaces_ok__Vec2 {
        return .{x: self.x + other.x, y: self.y + other.y};
    }
    fun neg(self: interfaces__multiple_interfaces_ok__Vec2) interfaces__multiple_interfaces_ok__Vec2 {
        return .{x: -self.x, y: -self.y};
    }
}
fun interfaces__multiple_interfaces_ok__f(
    a: interfaces__multiple_interfaces_ok__Vec2,
    b: interfaces__multiple_interfaces_ok__Vec2,
) interfaces__multiple_interfaces_ok__Vec2 {
