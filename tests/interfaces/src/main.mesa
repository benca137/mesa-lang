    @assert(interfaces__interface_default_method_ok__f(.{ tag: "dog-1" }) == "dog-1")
}

test "interfaces/interface_inheritance_ok.mesa" {
    let a: interfaces__interface_inheritance_ok__MyInt = .{ val: 1 }
    let b: interfaces__interface_inheritance_ok__MyInt = .{ val: 2 }
    @assert(interfaces__interface_inheritance_ok__f(a, b))
    @assert(!a.eq(b))
    @assert(b.eq(.{ val: 2 }))
}

