    @assert(9.109e-31 > 0.0)
}

test "edge_cases/literal_g_const_ok.mesa" {
    @assert(6.674e-11 > 0.0)
}

test "edge_cases/literal_large_ok.mesa" {
    @assert(1e10 == 10000000000.0)
}

test "edge_cases/literal_neg_one_ok.mesa" {
    @assert(-1.0 < 0.0)
}

test "edge_cases/literal_small_neg_exp_ok.mesa" {
    @assert(edge_cases__approx(1.5e-3, 0.0015))
}

test "edge_cases/literal_zero_ok.mesa" {
    @assert(0.0 == 0.0)
}

test "edge_cases/long_call_chain_ok.mesa" {
    @assert(edge_cases__inc(edge_cases__inc(edge_cases__inc(edge_cases__inc(edge_cases__inc(0))))) == 5)
}

test "edge_cases/many_params_ok.mesa" {
    @assert(edge_cases__many_params_sum(1, 2, 3, 4, 5, 1.0, 2.0, true) == 15)
