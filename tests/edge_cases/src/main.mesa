test "edge_cases/max_int_literal_ok.mesa" {
    @assert(9223372036854775807 > 0)
}

test "edge_cases/method_call_in_condition_ok.mesa" {
    let n: edge_cases__N = .{val: 5}
    let var seen = false
    if n.positive() { seen = true; }
    @assert(seen)
}

