test "edge_cases/nested_optional_struct_ok.mesa" {
    let pt: edge_cases__OptPtF64 = .{x: 2.0, y: 3.0}
    let p: ?edge_cases__OptPtF64 = pt
    if p |pt| {
        @assert(edge_cases__approx(pt.x * pt.y, 6.0))
    } else {
        @assert(false)
    }
}

test "edge_cases/one_error_suppresses_ok.mesa" {
    let result = @test.compile("fun f() void {\n    let x: bool = 42\n    let y = x + 1\n}\n")
    @assert(!result.ok)
    @assert(result.errors.len >= 1)
}

