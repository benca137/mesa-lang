    let n: edge_cases__SignedN = .{v: -2}
    @assert(n.is_pos() or n.is_neg())
}

test "edge_cases/min_negative_ok.mesa" {
    @assert(-9223372036854775807 < 0)
}

test "edge_cases/mixed_comparisons_ok.mesa" {
    @assert(1 < 2 and 2 < 3 and 1 != 3)
}

test "edge_cases/multi_let_ok.mesa" {
    let a: i64 = 1
    let b: i64 = 2
    let c: i64 = 3
    let d: i64 = 4
    let e: i64 = 5
    @assert(a + b + c + d + e == 15)
}

test "edge_cases/multi_return_ok.mesa" {
    @assert(edge_cases__sign(-5) == -1)
    @assert(edge_cases__sign(0) == 0)
    @assert(edge_cases__sign(7) == 1)
}

