fun functions__abs_ok__abs_i(x: i64) i64 {
    return if x < 0 { -x } else { x };
}
fun functions__abs_ok__abs_f(x: f64) f64 {
    return if x < 0.0 { -x } else { x };
}

fun functions__apply_closure_ok__apply(f: fun(i64) i64, x: i64) i64 { return f(x); }
fun functions__apply_closure_ok__double(x: i64) i64 { return x * 2; }
fun functions__apply_closure_ok__f() i64 { return functions__apply_closure_ok__apply(functions__apply_closure_ok__double, 5); }

fun functions__between_ok__between(x: i64, lo: i64, hi: i64) bool { return x >= lo and x <= hi; }

fun functions__closure_capture_float_ok__f(s: f64) fun(f64) f64 {
    return fun(x: f64) f64 { return x * s; };
}

fun functions__closure_capture_int_ok__f(n: i64) fun(i64) i64 {
    return fun(x: i64) i64 { return x + n; };
}

fun functions__closure_captures_ok__f(n: i64) fun(i64) i64 {
    return fun(x: i64) i64 { return x + n; };
}

fun functions__closure_no_capture_ok__f() fun(i64) i64 {
    return fun(x: i64) i64 { return x * x; };
}

fun functions__closure_ok__make_adder(n: i64) fun(i64) i64 {
    return fun(x: i64) i64 { return x + n; };
}

fun functions__curried_ok__add(a: i64) fun(i64) i64 {
    return fun(b: i64) i64 { return a + b; };
}

fun functions__fn_as_value_ok__double(x: i64) i64 { return x * 2; }
fun functions__fn_as_value_ok__apply(f: fun(i64) i64, x: i64) i64 { return f(x); }
fun functions__fn_as_value_ok__f() i64 { return functions__fn_as_value_ok__apply(functions__fn_as_value_ok__double, 5); }

fun functions__fn_param_fn_ok__transform(v: vec[i64], f: fun(i64) i64) i64 {
    let var sum: i64 = 0;
    for x in v { sum += f(x); }
    return sum;
}
fun functions__fn_param_fn_ok__triple(x: i64) i64 { return x * 3; }

fun functions__fn_param_optional_ok__f(x: ?i64, fallback: i64) i64 {
    return x orelse fallback;
}
fun functions__fn_param_optional_ok__some(x: i64) ?i64 { return x; }

fun functions__fn_param_predicate_ok__filter_count(v: vec[i64], pred: fun(i64) bool) i64 {
    let var c: i64 = 0;
    for x in v : pred(x) { c += 1; }
    return c;
}
fun functions__fn_param_predicate_ok__is_even(x: i64) bool { return x % 2 == 0; }

fun functions__fn_param_transform_ok__map_sum(v: vec[i64], f: fun(i64) i64) i64 {
    let var s: i64 = 0;
    for x in v { s += f(x); }
    return s;
}
fun functions__fn_param_transform_ok__square(x: i64) i64 { return x * x; }

fun functions__fn_return_optional_none_ok__find(v: vec[i64], n: i64) ?i64 {
    for i = 0...10 {
        if v[i] == n { return i; }
    }
    return none;
}

fun functions__fn_returns_fn_ok__make_multiplier(n: i64) fun(i64) i64 {
    return fun(x: i64) i64 { return x * n; };
}

fun functions__higher_order_ok__apply(f: fun(i64) i64, x: i64) i64 { return f(x); }
fun functions__higher_order_ok__inc(x: i64) i64 { return x + 1; }

fun functions__identity_i16_ok__identity(x: i16) i16 { return x; }
fun functions__identity_i32_ok__identity(x: i32) i32 { return x; }
fun functions__identity_i8_ok__identity(x: i8) i8 { return x; }
fun functions__identity_u16_ok__identity(x: u16) u16 { return x; }
fun functions__identity_u32_ok__identity(x: u32) u32 { return x; }
fun functions__identity_u64_ok__identity(x: u64) u64 { return x; }
fun functions__identity_u8_ok__identity(x: u8) u8 { return x; }

fun functions__inline_call_ok__double(x: i64) i64 { return x * 2; }
fun functions__inline_call_ok__f() i64 {
    return functions__inline_call_ok__double(functions__inline_call_ok__double(functions__inline_call_ok__double(1)));
}

inline fun functions__inline_fn_ok__fast(x: i64) i64 { return x * 2; }

fun functions__max_of_three_ok__max3(a: i64, b: i64, c: i64) i64 {
    let m: i64 = if a > b { a } else { b };
    return if m > c { m } else { c };
}

fun functions__min_of_three_ok__min3(a: f64, b: f64, c: f64) f64 {
    let m: f64 = if a < b { a } else { b };
    return if m < c { m } else { c };
}

fun functions__multiple_params_ok__add3(a: i64, b: i64, c: i64) i64 { return a + b + c; }

fun functions__multiple_returns_ok__f(x: i64) i64 {
    if x < 0 { return -1; }
    if x == 0 { return 0; }
    return 1;
}

fun functions__multireturn_paths_ok__grade(score: i64) str {
    if score >= 90 { return "A"; }
    if score >= 80 { return "B"; }
    if score >= 70 { return "C"; }
    if score >= 60 { return "D"; }
    return "F";
}

fun functions__mutual_recursion_bool_ok__even(n: i64) bool {
    if n == 0 { return true; }
    return functions__mutual_recursion_bool_ok__odd(n - 1);
}
fun functions__mutual_recursion_bool_ok__odd(n: i64) bool {
    if n == 0 { return false; }
    return functions__mutual_recursion_bool_ok__even(n - 1);
}

fun functions__mutual_recursion_ok__is_even(n: i64) bool {
    if n == 0 { return true; }
    return functions__mutual_recursion_ok__is_odd(n - 1);
}
fun functions__mutual_recursion_ok__is_odd(n: i64) bool {
    if n == 0 { return false; }
    return functions__mutual_recursion_ok__is_even(n - 1);
}

fun functions__no_params_ok__answer() i64 { return 42; }

fun functions__optional_param_ok__greet(name: str, greeting: ?str) str {
    let g: str = greeting orelse "Hello";
    return g;
}
fun functions__optional_param_ok__some(x: str) ?str { return x; }

fun functions__pipeline_ok__double(x: i64) i64 { return x * 2; }
fun functions__pipeline_ok__inc(x: i64) i64 { return x + 1; }
fun functions__pipeline_ok__square(x: i64) i64 { return x * x; }
fun functions__pipeline_ok__f(x: i64) i64 {
    return functions__pipeline_ok__square(functions__pipeline_ok__inc(functions__pipeline_ok__double(x)));
}

fun functions__predicate_ok__is_positive(x: i64) bool { return x > 0; }
fun functions__predicate_ok__is_even(x: i64) bool { return x % 2 == 0; }
fun functions__predicate_ok__f(x: i64) bool {
    return functions__predicate_ok__is_positive(x) and functions__predicate_ok__is_even(x);
}

fun functions__recursive_ok__factorial(n: i64) i64 {
    if n <= 1 { return 1; }
    return n * functions__recursive_ok__factorial(n - 1);
}

fun functions__return_bool_ok__f() bool {
    let x: bool = false;
    return x;
}

fun functions__return_f32_ok__f() f32 {
    let x: f32 = 0.0;
    return x;
}

fun functions__return_f64_ok__f() f64 {
    let x: f64 = 0.0;
    return x;
}

fun functions__return_i32_ok__f() i32 {
    let x: i32 = 0;
    return x;
}

fun functions__return_i64_ok__f() i64 {
    let x: i64 = 0;
    return x;
}

fun functions__return_optional_ok__safe_div(a: f64, b: f64) ?f64 {
    if b == 0.0 { return none; }
    return a / b;
}

fun functions__return_str_ok__f() str {
    let x: str = "ok";
    return x;
}

struct functions__return_struct_ok__Point { x: f64, y: f64 }
fun functions__return_struct_ok__make_point(x: f64, y: f64) functions__return_struct_ok__Point {
    return .{x: x, y: y};
}

fun functions__sign_ok__sign(x: f64) f64 {
    if x > 0.0 { return 1.0; }
    if x < 0.0 { return -1.0; }
    return 0.0;
}

fun functions__tail_call_ok__countdown(n: i64) i64 {
    if n <= 0 { return 0; }
    return functions__tail_call_ok__countdown(n - 1);
}

fun functions__variadic_like_ok__sum2(a: i64, b: i64) i64 { return a + b; }
fun functions__variadic_like_ok__sum3(a: i64, b: i64, c: i64) i64 { return a + b + c; }
fun functions__variadic_like_ok__f() i64 {
    return functions__variadic_like_ok__sum2(1, 2) + functions__variadic_like_ok__sum3(1, 2, 3);
}

fun functions__void_no_explicit_return_ok__f() void {
    let x: i64 = 1;
}
fun functions__void_no_explicit_return_ok__done() i64 {
    functions__void_no_explicit_return_ok__f();
    return 1;
}

test "functions/abs_ok.mesa" {
    @assert(functions__abs_ok__abs_i(-5) == 5)
    @assert(functions__abs_ok__abs_i(7) == 7)
    @assert(functions__abs_ok__abs_f(-1.25) == 1.25)
}

test "functions/apply_closure_ok.mesa" {
    @assert(functions__apply_closure_ok__f() == 10)
}

test "functions/between_ok.mesa" {
    @assert(functions__between_ok__between(5, 1, 10))
    @assert(!functions__between_ok__between(-1, 1, 10))
}

test "functions/closure_capture_float_ok.mesa" {
    let scale = functions__closure_capture_float_ok__f(2.5)
    @assert(scale(4.0) == 10.0)
}

test "functions/closure_capture_int_ok.mesa" {
    let add = functions__closure_capture_int_ok__f(7)
    @assert(add(5) == 12)
}

test "functions/closure_captures_ok.mesa" {
    let add = functions__closure_captures_ok__f(9)
    @assert(add(1) == 10)
}

