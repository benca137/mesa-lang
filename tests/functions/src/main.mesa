    let ok = functions__return_optional_ok__safe_div(8.0, 2.0)
    let bad = functions__return_optional_ok__safe_div(8.0, 0.0)
    if ok |v| { @assert(v == 4.0) } else { @assert(false) }
    if bad |v| { @assert(false) } else { @assert(true) }
}

