test "optionals/chain_orelse_ok.mesa" {
    @assert(optionals__chain_orelse_ok__f(optionals__helpers__some_i64(1), optionals__helpers__some_i64(2), optionals__helpers__some_i64(3)) == 1)
    @assert(optionals__chain_orelse_ok__f(none, optionals__helpers__some_i64(2), optionals__helpers__some_i64(3)) == 2)
    @assert(optionals__chain_orelse_ok__f(none, none, optionals__helpers__some_i64(3)) == 3)
    @assert(optionals__chain_orelse_ok__f(none, none, none) == 0)
}
test "optionals/chained_orelse_ok.mesa" {
    @assert(optionals__chained_orelse_ok__f(optionals__helpers__some_i64(4), optionals__helpers__some_i64(9)) == 4)
    @assert(optionals__chained_orelse_ok__f(none, optionals__helpers__some_i64(9)) == 9)
    @assert(optionals__chained_orelse_ok__f(none, none) == 0)
}
test "optionals/guard_clause_ok.mesa" {
    let positive = optionals__guard_clause_ok__safe_sqrt(9.0)
    if positive |v| { @assert(v == 9.0) } else { @assert(false) }
    @assert(optionals__helpers__is_none_f64(optionals__guard_clause_ok__safe_sqrt(-1.0)))
}
test "optionals/if_unwrap_chain_ok.mesa" {
    @assert(optionals__if_unwrap_chain_ok__f(optionals__helpers__some_i64(2), optionals__helpers__some_i64(3)) == 5)
    @assert(optionals__if_unwrap_chain_ok__f(optionals__helpers__some_i64(2), none) == 2)
    @assert(optionals__if_unwrap_chain_ok__f(none, optionals__helpers__some_i64(3)) == 0)
}
test "optionals/if_unwrap_no_else_ok.mesa" {
    @assert(optionals__if_unwrap_no_else_ok__f(optionals__helpers__some_i64(7)) == 7)
    @assert(optionals__if_unwrap_no_else_ok__f(none) == 0)
}
test "optionals/if_unwrap_ok.mesa" {
    @assert(optionals__if_unwrap_ok__f(optionals__helpers__some_i64(7)) == 7)
    @assert(optionals__if_unwrap_ok__f(none) == 0)
}
test "optionals/multi_unwrap_ok.mesa" {
    let both = optionals__multi_unwrap_ok__f(optionals__helpers__some_i64(2), optionals__helpers__some_i64(5))
    if both |v| { @assert(v == 7) } else { @assert(false) }
    @assert(optionals__helpers__is_none_i64(optionals__multi_unwrap_ok__f(optionals__helpers__some_i64(2), none)))
}
test "optionals/nested_opt_f64_ok.mesa" {
    @assert(optionals__nested_opt_f64_ok__f(optionals__helpers__some_opt_f64(optionals__helpers__some_f64(3.5))) == 3.5)
    @assert(optionals__nested_opt_f64_ok__f(optionals__helpers__some_opt_f64(none)) == 0.0)
    @assert(optionals__nested_opt_f64_ok__f(none) == 0.0)
}
test "optionals/nested_opt_i64_ok.mesa" {
    @assert(optionals__nested_opt_i64_ok__f(optionals__helpers__some_opt_i64(optionals__helpers__some_i64(3))) == 3)
    @assert(optionals__nested_opt_i64_ok__f(optionals__helpers__some_opt_i64(none)) == 0)
    @assert(optionals__nested_opt_i64_ok__f(none) == 0)
}
test "optionals/nested_optional_ok.mesa" {
    let inner = optionals__nested_optional_ok__f(optionals__helpers__some_opt_i64(optionals__helpers__some_i64(9)))
    if inner |v| { @assert(v == 9) } else { @assert(false) }
    @assert(optionals__helpers__is_none_i64(optionals__nested_optional_ok__f(optionals__helpers__some_opt_i64(none))))
    @assert(optionals__helpers__is_none_i64(optionals__nested_optional_ok__f(none)))
}
test "optionals/opt_and_then_ok.mesa" {
    let both = optionals__opt_and_then_ok__f(optionals__helpers__some_i64(4), optionals__helpers__some_i64(6))
    if both |v| { @assert(v == 10) } else { @assert(false) }
    @assert(optionals__helpers__is_none_i64(optionals__opt_and_then_ok__f(optionals__helpers__some_i64(4), none)))
}
test "optionals/opt_default_expr_ok.mesa" {
    @assert(optionals__opt_default_expr_ok__f(optionals__helpers__some_f64(2.0), 3.0) == 6.0)
    @assert(optionals__opt_default_expr_ok__f(none, 3.0) == 3.0)
}
