// optionals__chain_orelse_ok
fun optionals__chain_orelse_ok__f(a: ?i64, b: ?i64, c: ?i64) i64 {  //~ compile-ok
    return a orelse b orelse c orelse 0;
}

// optionals__chained_orelse_ok
fun optionals__chained_orelse_ok__f(a: ?i64, b: ?i64) i64 {  //~ compile-ok
    return a orelse b orelse 0;
}

// optionals__guard_clause_ok
fun optionals__guard_clause_ok__safe_sqrt(x: f64) ?f64 {  //~ compile-ok
    if x < 0.0 { return none; }
    return x;
}

// optionals__if_unwrap_chain_ok
fun optionals__if_unwrap_chain_ok__f(a: ?i64, b: ?i64) i64 {  //~ compile-ok
    if a |x| {
        if b |y| { return x + y; }
        return x;
    }
    return 0;
}

// optionals__if_unwrap_no_else_ok
fun optionals__if_unwrap_no_else_ok__f(x: ?i64) i64 {  //~ compile-ok
    let var y: i64 = 0;
    if x |v| { y = v; }
    return y;
}

// optionals__if_unwrap_ok
fun optionals__if_unwrap_ok__f(x: ?i64) i64 {  //~ compile-ok
    if x |v| { return v; } else { return 0; }
}

// optionals__multi_unwrap_ok
fun optionals__multi_unwrap_ok__f(a: ?i64, b: ?i64) ?i64 {  //~ compile-ok
    if a |x| {
        if b |y| {
            return x + y;
        }
    }
    return none;
}

// optionals__nested_opt_f64_ok
fun optionals__nested_opt_f64_ok__f(x: ??f64) f64 {  //~ compile-ok
