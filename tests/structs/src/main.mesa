    let b: structs__struct_optional_field_ok__Config = .{ name: "b", timeout: structs__struct_optional_field_ok__some(5), retries: 2 }
    @assert(structs__struct_optional_field_ok__timeout_or_default(a) == 30)
    @assert(structs__struct_optional_field_ok__timeout_or_default(b) == 5)
}

