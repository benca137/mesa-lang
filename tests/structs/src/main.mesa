test "structs/struct_reset_ok.mesa" {
    let var t: structs__struct_reset_ok__Timer = .{ elapsed: 5.0, limit: 3.0 }
    @assert(structs__struct_reset_ok__expired(t))
    structs__struct_reset_ok__reset(&t)
    @assert(t.elapsed == 0.0)
    @assert(!structs__struct_reset_ok__expired(t))
}

