struct structs__method_multi_field_ok__Particle {
    x: f64, y: f64, vx: f64, vy: f64,
    fun update(self: *structs__method_multi_field_ok__Particle, dt: f64) void {
        self.x = self.x + self.vx * dt;
        self.y = self.y + self.vy * dt;
    }
}

struct structs__multiple_methods_ok__Vec2 {
    x: f64, y: f64,
    fun dot(self: structs__multiple_methods_ok__Vec2, other: structs__multiple_methods_ok__Vec2) f64 {
        return self.x * other.x + self.y * other.y;
    }
    fun len_sq(self: structs__multiple_methods_ok__Vec2) f64 {
        return self.x * self.x + self.y * self.y;
    }
    fun scale(self: *structs__multiple_methods_ok__Vec2, factor: f64) void {
        self.x = self.x * factor;
        self.y = self.y * factor;
    }
}
fun structs__multiple_methods_ok__f(a: structs__multiple_methods_ok__Vec2, b: structs__multiple_methods_ok__Vec2) f64 { return a.dot(b); }

