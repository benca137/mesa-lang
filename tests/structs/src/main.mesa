}

struct structs__point_dist_sq_ok__P { x: f64, y: f64 }
fun structs__point_dist_sq_ok__dist_sq(a: structs__point_dist_sq_ok__P, b: structs__point_dist_sq_ok__P) f64 {
    let dx: f64 = a.x - b.x;
    let dy: f64 = a.y - b.y;
    return dx*dx + dy*dy;
}

