}

test "structs/vec3_cross_ok.mesa" {
    let v = structs__vec3_cross_ok__cross(.{ x: 1.0, y: 0.0, z: 0.0 }, .{ x: 0.0, y: 1.0, z: 0.0 })
    @assert(v.x == 0.0)
    @assert(v.y == 0.0)
    @assert(v.z == 1.0)
}

