fun structs__color_blend_ok__blend(a: structs__color_blend_ok__RGB, b: structs__color_blend_ok__RGB, t: f64) structs__color_blend_ok__RGB {
    return .{r: a.r+(b.r-a.r)*t, g: a.g+(b.g-a.g)*t, b: a.b+(b.b-a.b)*t};
}

