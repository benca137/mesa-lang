    @assert(structs__struct_return_ok__width(r) == 7)
}

test "structs/struct_three_methods_ok.mesa" {
    @assert(structs__struct_three_methods_ok__f() == 42)
    let var s: structs__struct_three_methods_ok__Stack = .{ top: 0, size: 0 }
    @assert(s.empty())
    s.push(9)
    @assert(!s.empty())
    @assert(s.pop() == 9)
}

test "structs/struct_update_field_ok.mesa" {
    let var c: structs__struct_update_field_ok__Counter = .{ n: 0, max: 2 }
    @assert(structs__struct_update_field_ok__tick(&c))
    @assert(c.n == 1)
    @assert(structs__struct_update_field_ok__tick(&c))
    @assert(!structs__struct_update_field_ok__tick(&c))
}

