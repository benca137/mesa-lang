    return .{
        x: a.y * b.z - a.z * b.y,
        y: a.z * b.x - a.x * b.z,
        z: a.x * b.y - a.y * b.x,
    };
}

test "structs/aabb_contains_ok.mesa" {
    let r: structs__aabb_contains_ok__AABB = .{ x: 0.0, y: 0.0, w: 10.0, h: 5.0 }
    @assert(structs__aabb_contains_ok__contains(r, 3.0, 2.0))
    @assert(!structs__aabb_contains_ok__contains(r, 10.0, 2.0))
}

test "structs/basic_struct_ok.mesa" {
    let p: structs__basic_struct_ok__Point = .{ x: 1.5, y: 2.5 }
    @assert(structs__basic_struct_ok__f(p) == 4.0)
}

test "structs/color_blend_ok.mesa" {
    let a: structs__color_blend_ok__RGB = .{ r: 0.0, g: 0.5, b: 1.0 }
    let b: structs__color_blend_ok__RGB = .{ r: 1.0, g: 0.5, b: 0.0 }
    let mixed = structs__color_blend_ok__blend(a, b, 0.25)
    @assert(mixed.r == 0.25)
    @assert(mixed.g == 0.5)
    @assert(mixed.b == 0.75)
}

test "structs/field_chain_ok.mesa" {
    let c: structs__field_chain_ok__C = .{ b: .{ a: .{ x: 9 } } }
    @assert(structs__field_chain_ok__f(c) == 9)
}

test "structs/method_multi_field_ok.mesa" {
    let var p: structs__method_multi_field_ok__Particle = .{ x: 0.0, y: 0.0, vx: 2.0, vy: -1.0 }
    p.update(0.5)
    @assert(p.x == 1.0)
    @assert(p.y == -0.5)
}

test "structs/multiple_methods_ok.mesa" {
    let var a: structs__multiple_methods_ok__Vec2 = .{ x: 2.0, y: 3.0 }
    let b: structs__multiple_methods_ok__Vec2 = .{ x: 4.0, y: 5.0 }
    @assert(structs__multiple_methods_ok__f(a, b) == 23.0)
    @assert(a.len_sq() == 13.0)
    a.scale(2.0)
    @assert(a.x == 4.0)
    @assert(a.y == 6.0)
}

test "structs/nested_struct_access_ok.mesa" {
    let o: structs__nested_struct_access_ok__Outer = .{ inner: .{ val: 11 }, tag: true }
    @assert(structs__nested_struct_access_ok__f(o) == 11)
}

test "structs/nested_struct_ok.mesa" {
    let r: structs__nested_struct_ok__Rect = .{ pos: .{ x: 1.0, y: 2.0 }, size: .{ x: 3.0, y: 4.0 } }
    @assert(structs__nested_struct_ok__area(r) == 12.0)
}

test "structs/plane_dist_ok.mesa" {
    let p: structs__plane_dist_ok__Plane = .{ nx: 1.0, ny: 2.0, nz: 3.0, d: 4.0 }
    @assert(structs__plane_dist_ok__dist(p, 1.0, 1.0, 1.0) == 10.0)
}

test "structs/point_dist_sq_ok.mesa" {
    let a: structs__point_dist_sq_ok__P = .{ x: 1.0, y: 1.0 }
    let b: structs__point_dist_sq_ok__P = .{ x: 4.0, y: 5.0 }
    @assert(structs__point_dist_sq_ok__dist_sq(a, b) == 25.0)
}

test "structs/quat_norm_sq_ok.mesa" {
    let q: structs__quat_norm_sq_ok__Quat = .{ x: 1.0, y: 2.0, z: 3.0, w: 4.0 }
    @assert(structs__quat_norm_sq_ok__norm_sq(q) == 30.0)
}

