struct structs__aabb_contains_ok__AABB { x: f64, y: f64, w: f64, h: f64 }
fun structs__aabb_contains_ok__contains(r: structs__aabb_contains_ok__AABB, px: f64, py: f64) bool {
    return px >= r.x and px < r.x + r.w and py >= r.y and py < r.y + r.h;
}

