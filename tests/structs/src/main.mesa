struct structs__struct_three_methods_ok__Stack {
    top: i64,
    size: i64,
    fun push(self: *structs__struct_three_methods_ok__Stack, v: i64) void { self.top = v; self.size = self.size + 1; }
    fun pop(self: *structs__struct_three_methods_ok__Stack) i64 { self.size = self.size - 1; return self.top; }
    fun empty(self: structs__struct_three_methods_ok__Stack) bool { return self.size == 0; }
}
fun structs__struct_three_methods_ok__f() i64 {
    let var s: structs__struct_three_methods_ok__Stack = .{top: 0, size: 0};
    s.push(42);
    return s.pop();
}

