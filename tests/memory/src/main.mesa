// memory__mut_method_updates_ok
struct memory__mut_method_updates_ok__Stack { top: i64 }
fun memory__mut_method_updates_ok__push(s: *memory__mut_method_updates_ok__Stack, val: i64) void {  //~ compile-ok
    s.top = val;
}
fun memory__mut_method_updates_ok__pop(s: *memory__mut_method_updates_ok__Stack) i64 {
    let v: i64 = s.top;
    s.top = 0;
    return v;
}

// memory__pointer_arithmetic_like_ok
fun memory__pointer_arithmetic_like_ok__write_zero(p: *i64) void {  //~ compile-ok
    *p = 0;
}
fun memory__pointer_arithmetic_like_ok__f() i64 {
    let var x: i64 = 42;
    memory__pointer_arithmetic_like_ok__write_zero(&x);
    return x;
}

// memory__pointer_basic_ok
fun memory__pointer_basic_ok__f() i64 {  //~ compile-ok
    let var x: i64 = 42;
    let p: *i64 = &x;
    return *p;
}

// memory__pointer_mutation_ok
fun memory__pointer_mutation_ok__f() i64 {  //~ compile-ok
    let var x: i64 = 0;
    let p: *i64 = &x;
    *p = 42;
    return x;
}

// memory__pointer_to_struct_ok
struct memory__pointer_to_struct_ok__Vec2 { x: f64, y: f64 }
fun memory__pointer_to_struct_ok__zero(v: *memory__pointer_to_struct_ok__Vec2) void {  //~ compile-ok
    v.x = 0.0;
    v.y = 0.0;
}
fun memory__pointer_to_struct_ok__f() f64 {
    let var v: memory__pointer_to_struct_ok__Vec2 = .{x: 3.0, y: 4.0};
    memory__pointer_to_struct_ok__zero(&v);
    return v.x + v.y;
}

