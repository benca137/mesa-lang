// memory__struct_pointer_ok
struct memory__struct_pointer_ok__Point { x: f64, y: f64 }
fun memory__struct_pointer_ok__zero(p: *memory__struct_pointer_ok__Point) void {  //~ compile-ok
    p.x = 0.0;
    p.y = 0.0;
}
fun memory__struct_pointer_ok__f() f64 {
    let var p: memory__struct_pointer_ok__Point = .{x: 9.0, y: 2.0};
