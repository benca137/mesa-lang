// memory__swap_via_pointer_ok
fun memory__swap_via_pointer_ok__swap(a: *i64, b: *i64) void {  //~ compile-ok
    let tmp: i64 = *a;
    *a = *b;
    *b = tmp;
}

test "memory/mut_method_updates_ok.mesa" {
    let var s: memory__mut_method_updates_ok__Stack = .{top: 0};
    memory__mut_method_updates_ok__push(&s, 9);
    @assert(memory__mut_method_updates_ok__pop(&s) == 9)
    @assert(s.top == 0)
}

test "memory/pointer_arithmetic_like_ok.mesa" {
    @assert(memory__pointer_arithmetic_like_ok__f() == 0)
}

test "memory/pointer_basic_ok.mesa" {
    @assert(memory__pointer_basic_ok__f() == 42)
}

test "memory/pointer_mutation_ok.mesa" {
    @assert(memory__pointer_mutation_ok__f() == 42)
}

test "memory/pointer_to_struct_ok.mesa" {
    @assert(memory__pointer_to_struct_ok__f() == 0.0)
}

test "memory/ptr_bool_ok.mesa" {
    @assert(!memory__ptr_bool_ok__f())
}

test "memory/ptr_f64_ok.mesa" {
    @assert(memory__ptr_f64_ok__f() == 0.0)
}

test "memory/ptr_i32_ok.mesa" {
    @assert(memory__ptr_i32_ok__f() == 0)
}

test "memory/ptr_i64_ok.mesa" {
    @assert(memory__ptr_i64_ok__f() == 0)
}

test "memory/ptr_read_f32_ok.mesa" {
    let var x: f32 = 1.25;
    @assert(memory__ptr_read_f32_ok__f(&x) == 1.25)
}

test "memory/ptr_read_i16_ok.mesa" {
    let var x: i16 = 12;
    @assert(memory__ptr_read_i16_ok__f(&x) == 12)
}

test "memory/ptr_read_i32_ok.mesa" {
    let var x: i32 = 123;
    @assert(memory__ptr_read_i32_ok__f(&x) == 123)
}

test "memory/ptr_read_i8_ok.mesa" {
    let var x: i8 = 7;
    @assert(memory__ptr_read_i8_ok__f(&x) == 7)
}

test "memory/ptr_read_u32_ok.mesa" {
    let var x: u32 = 55;
    @assert(memory__ptr_read_u32_ok__f(&x) == 55)
}

test "memory/ptr_read_u64_ok.mesa" {
    let var x: u64 = 89;
    @assert(memory__ptr_read_u64_ok__f(&x) == 89)
}

test "memory/ptr_write_bool_ok.mesa" {
    let var x: bool = false;
    memory__ptr_write_bool_ok__write(&x, true);
    @assert(x)
}

test "memory/ptr_write_f64_ok.mesa" {
    let var x: f64 = 0.0;
    memory__ptr_write_f64_ok__write(&x, 6.5);
    @assert(x == 6.5)
}

test "memory/ptr_write_i32_ok.mesa" {
    let var x: i32 = 0;
    memory__ptr_write_i32_ok__write(&x, 77);
    @assert(x == 77)
}

test "memory/ptr_write_i64_ok.mesa" {
    let var x: i64 = 0;
    memory__ptr_write_i64_ok__write(&x, 88);
    @assert(x == 88)
}

test "memory/struct_pointer_ok.mesa" {
    @assert(memory__struct_pointer_ok__f() == 0.0)
}

test "memory/swap_via_pointer_ok.mesa" {
    let var a: i64 = 3;
    let var b: i64 = 8;
    memory__swap_via_pointer_ok__swap(&a, &b);
    @assert(a == 8)
    @assert(b == 3)
}
