// loops__count_while_ok
fun loops__helpers__some_i64(x: i64) ?i64 {
    return x;
}

// loops__count_while_ok
fun loops__count_while_ok__f(n: i64) i64 {  //~ compile-ok
    let var c: i64 = 0;
    let var x: i64 = n;
    while x > 1 {
        x = x / 2;
        c += 1;
    }
    return c;
}

// loops__fib_loop_ok
fun loops__fib_loop_ok__fib(n: i64) i64 {  //~ compile-ok
    let var a: i64 = 0;
    let var b: i64 = 1;
    for i = 0...n {
        let t: i64 = b;
        b = a + b;
        a = t;
    }
    return a;
}

// loops__for_break_continue_ok
fun loops__for_break_continue_ok__f() i64 {  //~ compile-ok
    let var s: i64 = 0;
    for i = 0...20 {
        if i % 3 == 0 { continue; }
        if s > 50 { break; }
        s += i;
    }
    return s;
}

// loops__for_exclusive_0_10_ok
fun loops__for_exclusive_0_10_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0..10 { t += i; }
    return t;
}

// loops__for_filter_count_ok
fun loops__for_filter_count_ok__count_even(n: i64) i64 {  //~ compile-ok
    let var c: i64 = 0;
    for i = 0...n : i % 2 == 0 { c += 1; }
    return c;
}

// loops__for_filter_sum_odd_ok
fun loops__for_filter_sum_odd_ok__sum_odd(n: i64) i64 {  //~ compile-ok
    let var s: i64 = 0;
    for i = 0...n : i % 2 != 0 { s += i; }
    return s;
}

// loops__for_inclusive_0_10_ok
fun loops__for_inclusive_0_10_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0...10 { t += i; }
    return t;
}

// loops__for_inclusive_1_5_ok
fun loops__for_inclusive_1_5_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 1...5 { t += i; }
    return t;
}

// loops__for_iter_index_ok
fun loops__for_iter_index_ok__f() i64 {  //~ compile-ok
    let v = vec[10, 20, 30, 40, 50];
    let var sum: i64 = 0;
    for i = 0...4 {
        let x: i64 = v[i];
        sum += x;
    }
    return sum;
}

// loops__for_iter_ref_ok
fun loops__for_iter_ref_ok__f() i64 {  //~ compile-ok
    let var v = vec[1, 2, 3];
    for *x in v {
        *x += 1;
    }
    return v[0] + v[1] + v[2];
}

// loops__for_iter_vec_ok
fun loops__for_iter_vec_ok__f() i64 {  //~ compile-ok
    let v = vec[1, 2, 3];
    let var sum: i64 = 0;
    for x in v {
        let y: i64 = x;
        sum += y;
    }
    return sum;
}

// loops__for_iter_with_filter_ok
fun loops__for_iter_with_filter_ok__f() i64 {  //~ compile-ok
    let v = vec[1, 2, 3, 4, 5];
    let var sum: i64 = 0;
    for x in v : x > 2 {
        let y: i64 = x;
        sum += y;
    }
    return sum;
}

// loops__for_large_range_ok
fun loops__for_large_range_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0...100 { t += i; }
    return t;
}

// loops__for_nested_break_ok
fun loops__for_nested_break_ok__f() i64 {  //~ compile-ok
    let var found: i64 = -1;
    outer: for i = 0...10 {
        for j = 0...10 {
            if i * j > 50 {
                found = i;
                break outer;
            }
        }
    }
    return found;
}

// loops__for_offset_5_15_ok
fun loops__for_offset_5_15_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 5..15 { t += i; }
    return t;
}

// loops__for_range_exclusive_ok
fun loops__for_range_exclusive_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0..10 { t += i; }
    return t;
}

// loops__for_range_inclusive_ok
fun loops__for_range_inclusive_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0...10 { t += i; }
    return t;
}

// loops__for_range_reverse_ok
fun loops__for_range_reverse_ok__f(n: i64) i64 {  //~ compile-ok
    let var i: i64 = n;
    while i > 0 {
        i -= 1;
    }
    return i;
}

// loops__for_range_single_iteration_ok
fun loops__for_range_single_iteration_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 5...5 {
        t += i;
    }
    return t;
}

// loops__for_range_step_via_filter_ok
fun loops__for_range_step_via_filter_ok__sum_even(n: i64) i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0...n : i % 2 == 0 { t += i; }
    return t;
}

// loops__for_range_with_filter_ok
fun loops__for_range_with_filter_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0...10 : i % 2 == 0 { t += i; }
    return t;
}

// loops__for_range_zero_iterations_ok
fun loops__for_range_zero_iterations_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 5...3 {
        t += i;
    }
    return t;
}

// loops__for_vec_enumerate_ok
fun loops__for_vec_enumerate_ok__find_first(v: vec[i64], needle: i64) i64 {  //~ compile-ok
    for i = 0...99 {
        if v[i] == needle { return i; }
    }
    return -1;
}

// loops__for_zero_range_ok
fun loops__for_zero_range_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0...0 { t += i; }
    return t;
}

// loops__loop_var_scoped_ok
fun loops__loop_var_scoped_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0...10 { t += i; }
    return t;
}

// loops__nested_for_sum_ok
fun loops__nested_for_sum_ok__f(n: i64) i64 {  //~ compile-ok
    let var s: i64 = 0;
    for i = 0...n {
        for j = 0...n {
            s += i * j;
        }
    }
    return s;
}

// loops__nested_loops_ok
fun loops__nested_loops_ok__f() i64 {  //~ compile-ok
    let var t: i64 = 0;
    for i = 0...5 {
        for j = 0...5 {
            t += i * j;
        }
    }
    return t;
}

// loops__nested_mult_ok
fun loops__nested_mult_ok__mat_sum(n: i64) i64 {  //~ compile-ok
    let var s: i64 = 0;
    for i = 0...n {
        for j = 0...n {
            s += i * j;
        }
    }
    return s;
}

// loops__product_ok
fun loops__product_ok__product(n: i64) i64 {  //~ compile-ok
    let var p: i64 = 1;
    for i = 1...n { p *= i; }
    return p;
}

// loops__sum_squares_ok
fun loops__sum_squares_ok__f(n: i64) i64 {  //~ compile-ok
    let var s: i64 = 0;
    for i = 1...n { s += i * i; }
    return s;
}

// loops__while_basic_ok
fun loops__while_basic_ok__f() i64 {  //~ compile-ok
    let var x: i64 = 10;
    while x > 0 { x -= 1; }
    return x;
}

// loops__while_loop_accumulator_ok
fun loops__while_loop_accumulator_ok__power(base: i64, exp: i64) i64 {  //~ compile-ok
    let var result: i64 = 1;
    let var e: i64 = exp;
    while e > 0 {
        result *= base;
        e -= 1;
    }
    return result;
}

// loops__while_until_ok
fun loops__while_until_ok__f(start: i64, target: i64) i64 {  //~ compile-ok
    let var x: i64 = start;
    let var steps: i64 = 0;
    while x != target {
        if x < target { x += 1; } else { x -= 1; }
        steps += 1;
    }
    return steps;
}

// loops__while_unwrap_ok
fun loops__while_unwrap_ok__f(x: ?i64) i64 {  //~ compile-ok
    while x |v| {
        return v;
    }
    return 0;
}

// loops__while_with_optional_ok
fun loops__while_with_optional_ok__f(start: ?i64) i64 {  //~ compile-ok
    let var x: i64 = start orelse 0;
    while x < 10 { x += 1; }
    return x;
}

test "loops/count_while_ok.mesa" {
    @assert(loops__count_while_ok__f(1) == 0)
    @assert(loops__count_while_ok__f(8) == 3)
    @assert(loops__count_while_ok__f(20) == 4)
}

